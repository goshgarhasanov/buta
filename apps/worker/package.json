{
  "name": "@buta/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Buta video processing worker (FFmpeg + BullMQ)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "bullmq": "^5.34.10",
    "dotenv": "^16.4.7",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.4.2",
    "minio": "^8.0.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
