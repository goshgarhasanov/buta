# Application
NODE_ENV=development
PORT=4000
WS_PORT=4001
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL="postgresql://buta:buta_dev_password@localhost:5432/buta?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_me_dev_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_dev_refresh_secret_min_32_chars_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=butaadmin
S3_SECRET_KEY=butaadmin123
S3_BUCKET_VIDEOS=buta-videos
S3_BUCKET_THUMBNAILS=buta-thumbnails
S3_BUCKET_AVATARS=buta-avatars
S3_PUBLIC_URL=http://localhost:9000

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_KEY=buta_meili_dev_key

# Mail (Mailhog dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Buta <no-reply@buta.az>"

# OTP / SMS (gələcəkdə)
